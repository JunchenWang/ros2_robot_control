{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
         {
            "name": "ROS2 Debug: robot_math",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/install/robot_math/lib/robot_math/test_robot_math",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            // "preLaunchTask": "colcon build current package",
            "setupCommands": [
                {
                    "description": "Enable GDB pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },


        {
            "name": "ROS2 Python Debug: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                    // "--ros-args",
                    // "--params-file",
                    // "${workspaceFolder}/src/my_py_pkg/config/params.yaml"
                    ],
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "justMyCode": false
        }
    ]
}